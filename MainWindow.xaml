<ui:FluentWindow x:Class="AjazzKeyboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="AjazzKeyboard"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="#6C7086"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="12,10"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Width"                      Value="176"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E1E2E"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="AJAZZ Keyboard Configurator"
                     ShowMinimize="True" ShowMaximize="True" ShowClose="True">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <ui:SymbolIcon Symbol="Keyboard24" FontSize="18" Foreground="#89B4FA" Margin="0,0,8,0"/>
                    <TextBlock Text="AjazzKeyboard" FontSize="14" FontWeight="SemiBold"
                               Foreground="#CDD6F4" VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Main layout: sidebar + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#11111B">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nav items -->
                    <StackPanel Grid.Row="0" Margin="12,16,12,0">
                        <Button x:Name="BtnKeyboard" Content="Keyboard" Tag="Keyboard"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click" Margin="0,0,0,4">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Keyboard24" FontSize="16" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <Button x:Name="BtnRgb" Content="RGB Lighting" Tag="RGB"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click" Margin="0,0,0,4">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="LightbulbFilament24" FontSize="16" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <Button x:Name="BtnProfiles" Content="Profiles" Tag="Profiles"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click" Margin="0,0,0,4">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="DocumentMultiple24" FontSize="16" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>

                    <!-- Footer: connection status -->
                    <Border Grid.Row="1" Margin="12,0,12,16" Padding="12,10"
                            Background="#1E1E2E" CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ConnDot" Width="8" Height="8" Margin="0,0,8,0"
                                     Fill="#F44336" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ConnLabel" Text="Disconnected"
                                       Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Content area -->
            <Border Grid.Column="1" Background="#181825">
                <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" Background="Transparent"/>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
