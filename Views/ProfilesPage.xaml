<Page x:Class="AjazzKeyboard.Views.ProfilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Profiles" Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Profiles" FontSize="22" FontWeight="Bold" Foreground="#CDD6F4"/>
            <TextBlock Text="Save and load keyboard configurations."
                       FontSize="12" Foreground="#6C7086" Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Profile list -->
            <Border Background="#1E1E2E" CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="Saved Profiles" Foreground="#6C7086" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <ListBox ItemsSource="{Binding ProfileNames}"
                             SelectedItem="{Binding SelectedProfileName}"
                             Background="Transparent" BorderThickness="0"
                             MinHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="DocumentText24" FontSize="14" Foreground="#89B4FA" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding}" Foreground="#CDD6F4" FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Margin="0,1">
                                                <ContentPresenter Margin="8,4"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#313244"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#262637"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Actions panel -->
            <StackPanel Grid.Column="2">

                <!-- Save new profile -->
                <Border Background="#1E1E2E" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Save Current Config" Foreground="#CDD6F4"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="Profile name:" Foreground="#6C7086" FontSize="11" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="e.g. Gaming, Office…"/>
                            <ui:Button Grid.Column="2" Content="Save"
                                       Icon="{ui:SymbolIcon Save24}"
                                       Command="{Binding SaveProfileCommand}"
                                       Appearance="Primary" Padding="14,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Profile actions -->
                <Border Background="#1E1E2E" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Profile Actions" Foreground="#CDD6F4"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        <WrapPanel Orientation="Horizontal">
                            <ui:Button Content="Load" Icon="{ui:SymbolIcon ArrowDownload24}"
                                       Command="{Binding LoadProfileCommand}"
                                       Appearance="Secondary" Margin="0,0,8,8" Padding="14,6"/>
                            <ui:Button Content="Delete" Icon="{ui:SymbolIcon Delete24}"
                                       Command="{Binding DeleteProfileCommand}"
                                       Appearance="Caution" Margin="0,0,8,8" Padding="14,6"/>
                            <ui:Button Content="Export" Icon="{ui:SymbolIcon Share24}"
                                       Command="{Binding ExportProfileCommand}"
                                       Appearance="Secondary" Margin="0,0,8,8" Padding="14,6"/>
                            <ui:Button Content="Import" Icon="{ui:SymbolIcon FolderOpen24}"
                                       Command="{Binding ImportProfileCommand}"
                                       Appearance="Secondary" Margin="0,0,8,8" Padding="14,6"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="#A6E3A1"
                           FontSize="12" Margin="4,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
