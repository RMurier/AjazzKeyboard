<Page x:Class="AjazzKeyboard.Views.KeyboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:models="clr-namespace:AjazzKeyboard.Models"
      xmlns:conv="clr-namespace:AjazzKeyboard.Converters"
      xmlns:vm="clr-namespace:AjazzKeyboard.ViewModels"
      Title="Keyboard" Background="Transparent">

    <Page.Resources>

        <conv:NullToBoolConverter     x:Key="NullToBool"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:KeyActionTypeConverter  x:Key="ActionTypeDisplay"/>

        <Style x:Key="LcdKeyStyle" TargetType="Button">
            <Setter Property="Background"      Value="#1E2030"/>
            <Setter Property="BorderBrush"     Value="#45475A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#89B4FA"/>
                                <Setter TargetName="Root" Property="Background"  Value="#2A2D40"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#313244"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush"     Value="#89B4FA"/>
                                <Setter TargetName="Root" Property="Background"      Value="#2A3550"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="3"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="AJAZZ AKP153" FontSize="20" FontWeight="Bold" Foreground="#CDD6F4"/>
                <TextBlock Text="Click a key to configure its LCD label or image."
                           FontSize="12" Foreground="#6C7086" Margin="0,2,0,0"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12" Foreground="#A6E3A1" FontWeight="SemiBold" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Column="1" CornerRadius="20" Padding="12,5" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#3E1E1E"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                <Setter Property="Background" Value="#1E3E1E"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,7,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#F38BA8"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#A6E3A1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="Disconnected"/>
                                <Setter Property="Foreground" Value="#F38BA8"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Text"       Value="Connected"/>
                                        <Setter Property="Foreground" Value="#A6E3A1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ui:Button Content="Connect" Margin="10,0,0,0" Padding="8,2" FontSize="11"
                               Appearance="Secondary" Command="{Binding TryConnectCommand}"/>
                    <ui:Button Content="Reconnect" Margin="6,0,0,0" Padding="8,2" FontSize="11"
                               Appearance="Secondary" Command="{Binding ForceReconnectCommand}"
                               ToolTip="Disconnects and reconnects (no cable unplug needed) — test whether this forces the panel to redraw keys that wrote OK but never actually rendered"/>
                    <ui:Button Content="Show grid numbers" Margin="6,0,0,0" Padding="8,2" FontSize="11"
                               Appearance="Secondary" Command="{Binding ShowGridNumbersCommand}"
                               ToolTip="Sends numbers 1-15 to every physical key at once (raw hardware order), so you can read the whole pad layout in one glance"/>
                    <ui:Button Content="Probe -50..50" Margin="6,0,0,0" Padding="8,2" FontSize="11"
                               Appearance="Secondary" Command="{Binding ProbeKeyRangeCommand}"
                               ToolTip="Sends the raw device index (-50 to 50) to every possible slot, to find extra addressable elements like the side bar. Takes a few minutes."/>
                    <ui:Button Content="Calibrate Grid" Margin="6,0,0,0" Padding="8,2" FontSize="11"
                               Appearance="Secondary" Command="{Binding CalibrateGridCommand}"
                               ToolTip="Sends a number to a physical key, then click the matching key on the pad above. Repeats for all keys and saves the mapping."/>
                    <ui:Button Content="Scan HID" Margin="6,0,0,0" Padding="8,2" FontSize="11"
                               Appearance="Secondary" Command="{Binding ScanDevicesCommand}"
                               ToolTip="List all connected HID devices (for debugging)"/>
                    <ui:Button Content="Test brightness" Margin="6,0,0,0" Padding="8,2" FontSize="11"
                               Appearance="Secondary" Command="{Binding TestBrightnessCommand}"
                               ToolTip="Send LIG command — simplest HID write test"/>
                    <ui:Button Content="Send all" Margin="6,0,0,0" Padding="8,2" FontSize="11"
                               Appearance="Primary" Command="{Binding SendAllToDeviceCommand}"
                               ToolTip="Send all key images to device"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── 3×5 LCD Pad ─────────────────────────────────────────────── -->
        <Border Grid.Row="1" Margin="24,0,24,0"
                Background="#11111B" CornerRadius="14" Padding="20">
            <ItemsControl ItemsSource="{Binding Keys}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="3" Columns="5"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:KeyInfo}">
                        <Button Width="90" Height="90" Margin="5"
                                Style="{StaticResource LcdKeyStyle}"
                                Command="{Binding DataContext.SelectKeyCommand,
                                          RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}">
                            <Grid>
                                <!-- LCD image -->
                                <Image Source="{Binding PreviewImage}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <!-- Label (visible when no image) -->
                                <TextBlock Text="{Binding Label}"
                                           Foreground="#CDD6F4" FontSize="11" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center" Padding="6">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PreviewImage,
                                                             Converter={StaticResource NullToBool}}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Key index badge -->
                                <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Margin="4" Padding="3,1" CornerRadius="3"
                                        Background="#AA1E1E2E">
                                    <TextBlock Text="{Binding Index}"
                                               FontSize="8" Foreground="#CDD6F4"/>
                                </Border>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ── Config panel ────────────────────────────────────────────── -->
        <Border Grid.Row="2" Margin="24,12,24,24"
                Background="#1E1E2E" CornerRadius="14" Padding="20">
            <Grid>

                <!-- No key selected -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedKey}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon Symbol="Keyboard24" FontSize="32" Foreground="#313244"
                                   HorizontalAlignment="Center"/>
                    <TextBlock Text="Click a key on the pad above"
                               Foreground="#45475A" FontSize="13" Margin="0,8,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Key selected -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedKey}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- LCD preview (85×85) -->
                    <Border Grid.Column="0" Width="85" Height="85"
                            Background="#0A0A0A" CornerRadius="8"
                            BorderBrush="#89B4FA" BorderThickness="2"
                            ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding SelectedKey.PreviewImage}"
                                   Stretch="UniformToFill"/>
                            <TextBlock Text="{Binding SelectedKey.Label}"
                                       Foreground="#CDD6F4" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center" Padding="6">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedKey.PreviewImage,
                                                         Converter={StaticResource NullToBool}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Label + Image controls -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="Label (text on LCD):" Foreground="#6C7086"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding EditLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" Height="36" Padding="8,4"
                                     Background="#313244" Foreground="#CDD6F4"
                                     BorderBrush="#45475A" VerticalContentAlignment="Center"/>
                            <ui:Button Grid.Column="1" Content="Set" Padding="14,0" Height="36"
                                       Margin="8,0,0,0" Appearance="Secondary"
                                       Command="{Binding ApplyLabelCommand}"/>
                        </Grid>

                        <Separator Margin="0,12,0,12" Background="#313244"/>

                        <TextBlock Text="LCD image:" Foreground="#6C7086"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="Choose image…"
                                       Command="{Binding PickImageCommand}"
                                       Appearance="Secondary" Padding="12,8"/>
                            <ui:Button Content="Clear" Margin="8,0,0,0" Padding="12,8"
                                       Command="{Binding ClearImageCommand}"
                                       Appearance="Secondary"/>
                            <TextBlock Foreground="#6C7086" FontSize="11"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       MaxWidth="200" TextTrimming="CharacterEllipsis"
                                       Text="{Binding SelectedKey.ImagePath}"/>
                        </StackPanel>

                        <Separator Margin="0,12,0,12" Background="#313244"/>

                        <!-- ── Action on press ──────────────────────────── -->
                        <TextBlock Text="Action on key press:" Foreground="#6C7086"
                                   FontSize="11" Margin="0,0,0,6"/>

                        <ComboBox ItemsSource="{x:Static vm:KeyboardPageViewModel.ActionTypeNames}"
                                  SelectedItem="{Binding EditActionTypeName, Mode=TwoWay}"
                                  Height="32" Background="#313244" Foreground="#CDD6F4"
                                  BorderBrush="#45475A" Padding="8,4"/>

                        <!-- Hotkey sub-panel -->
                        <StackPanel Margin="0,8,0,0"
                                    Visibility="{Binding IsHotkeyAction, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox Content="Ctrl"  IsChecked="{Binding EditCtrl}"
                                          Foreground="#CDD6F4" Margin="0,0,14,0"/>
                                <CheckBox Content="Alt"   IsChecked="{Binding EditAlt}"
                                          Foreground="#CDD6F4" Margin="0,0,14,0"/>
                                <CheckBox Content="Shift" IsChecked="{Binding EditShift}"
                                          Foreground="#CDD6F4" Margin="0,0,14,0"/>
                                <CheckBox Content="Win"   IsChecked="{Binding EditWin}"
                                          Foreground="#CDD6F4"/>
                            </StackPanel>
                            <TextBox Text="{Binding EditHotkeyKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="8,4" Background="#313244"
                                     Foreground="#CDD6F4" BorderBrush="#45475A"
                                     VerticalContentAlignment="Center"
                                     ToolTip="F5 · Enter · A · Space · VolumeUp · MediaPlay …"/>
                        </StackPanel>

                        <!-- Launch app sub-panel -->
                        <StackPanel Margin="0,8,0,0"
                                    Visibility="{Binding IsAppAction, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding EditAppPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32" Padding="8,4" Background="#313244"
                                         Foreground="#CDD6F4" BorderBrush="#45475A"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Full path to .exe or file"/>
                                <ui:Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                           Height="32" Padding="10,0" Appearance="Secondary"
                                           Command="{Binding BrowseAppCommand}"/>
                            </Grid>
                            <TextBox Text="{Binding EditAppArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,0" Height="32" Padding="8,4" Background="#313244"
                                     Foreground="#CDD6F4" BorderBrush="#45475A"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Optional command line arguments"/>
                        </StackPanel>

                        <!-- Type text sub-panel -->
                        <TextBox Margin="0,8,0,0"
                                 Text="{Binding EditMacroText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32" Padding="8,4" Background="#313244"
                                 Foreground="#CDD6F4" BorderBrush="#45475A"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Text to type when key is pressed"
                                 Visibility="{Binding IsMacroAction, Converter={StaticResource BoolToVis}}"/>

                        <ui:Button Content="Apply action" Margin="0,8,0,0" Padding="12,8"
                                   Appearance="Secondary" HorizontalAlignment="Left"
                                   Command="{Binding ApplyActionCommand}"/>

                        <ui:Button Content="Simulate press (2s delay)" Margin="0,4,0,0" Padding="12,8"
                                   Appearance="Secondary" HorizontalAlignment="Left"
                                   Command="{Binding SimulatePressCommand}"
                                   ToolTip="Wait 2 seconds then triggers action (useful to test without the pad)"/>

                        <!-- Current action hint -->
                        <TextBlock Text="{Binding SelectedKey.ActionDescription}"
                                   Foreground="#585B70" FontSize="11" Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Send button -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="20,0,0,0">
                        <ui:Button Content="Send to device"
                                   Command="{Binding SendToDeviceCommand}"
                                   Appearance="Primary" Padding="16,10"
                                   HorizontalAlignment="Stretch"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#A6E3A1" FontSize="11"
                                   Margin="0,10,0,0" TextWrapping="Wrap"
                                   MaxWidth="160" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</Page>
